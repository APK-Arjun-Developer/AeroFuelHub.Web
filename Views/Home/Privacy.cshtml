@{
    ViewData["Title"] = "Privacy Policy";
    ViewData["Subtitle"] = "How AeroFuel Hub handles your information";
}

<div class="card card-app">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-shield-halved me-2 text-primary" aria-hidden="true"></i>Privacy policy
        </h3>
    </div>
    <div class="card-body">
        <div class="privacy-section">
            <h4>Overview</h4>
            <p>
                AeroFuel Hub is an aviation fuel management platform. This policy describes what information we collect,
                how we use it, and how we protect data entered by airlines, fuel suppliers, and coordinators.
            </p>
        </div>

        <div class="privacy-section">
            <h4>Information we collect</h4>
            <ul>
                <li>Account details such as name, email address, and assigned role</li>
                <li>Fuel transaction records including flight, airline, airport, quantities, and amounts</li>
                <li>Activity related to reports, invoices, and system access</li>
            </ul>
        </div>

        <div class="privacy-section">
            <h4>How we use your data</h4>
            <ul>
                <li>To operate fuel transaction workflows and role-based dashboards</li>
                <li>To generate reports and invoices for authorized users</li>
                <li>To maintain security, audit trails, and system integrity</li>
            </ul>
        </div>

        <div class="privacy-section">
            <h4>Data security</h4>
            <p>
                Access is restricted by role. Users only see data permitted for their organization.
                Passwords are stored using industry-standard hashing. Always sign out on shared devices.
            </p>
        </div>

        <div class="privacy-section mb-0">
            <h4>Contact</h4>
            <p class="mb-0">
                For privacy questions or data requests, contact your AeroFuel Hub administrator or IT support team.
            </p>
        </div>
    </div>
</div>
