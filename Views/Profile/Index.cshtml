@using AeroFuelHub.Web.Constants
@model AeroFuelHub.Web.ViewModels.Profile.ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
    ViewData["Subtitle"] = "View and update your account information";
    var roleBadgeClass = Model.Role switch
    {
        Roles.Admin => "status-badge--danger",
        Roles.AirlineExecutive => "status-badge--info",
        Roles.FuelSupplyExecutive => "status-badge--success",
        Roles.FuelCoordinator => "status-badge--warning",
        _ => "status-badge--neutral"
    };
}

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card card-app">
            <div class="card-body text-center py-4">
                <div class="profile-avatar mx-auto mb-3" aria-hidden="true">
                    @(string.IsNullOrWhiteSpace(Model.FullName) ? "?" : char.ToUpper(Model.FullName[0]))
                </div>
                <h4 class="mb-1">@Model.FullName</h4>
                <p class="text-muted small mb-2">@Model.Email</p>
                <span class="status-badge @roleBadgeClass">@Model.Role</span>
                @if (!string.IsNullOrWhiteSpace(Model.Airline))
                {
                    <p class="small text-muted mt-3 mb-0"><i class="fas fa-plane me-1" aria-hidden="true"></i>@Model.Airline</p>
                }
                @if (!string.IsNullOrWhiteSpace(Model.FuelCompany))
                {
                    <p class="small text-muted mt-3 mb-0"><i class="fas fa-building me-1" aria-hidden="true"></i>@Model.FuelCompany</p>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Airport))
                {
                    <p class="small text-muted mt-3 mb-0"><i class="fas fa-location-dot me-1" aria-hidden="true"></i>@Model.Airport</p>
                }
            </div>
            <div class="card-footer bg-transparent border-top d-grid">
                <a asp-action="ChangePassword" class="btn btn-outline-primary btn-sm">
                    <i class="fas fa-key me-1" aria-hidden="true"></i>Change password
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card card-app">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-user-pen me-2 text-primary" aria-hidden="true"></i>Edit profile
                </h3>
            </div>
            <form asp-controller="Profile" asp-action="Index" method="post" id="profileForm">
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                    <div class="form-section mb-0">
                        <h4 class="form-section__title">Editable fields</h4>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="FullName" class="form-label"></label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" class="form-control" autocomplete="email" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-section mb-0 mt-4">
                        <h4 class="form-section__title">Account info (read-only)</h4>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Role" class="form-label"></label>
                                <input value="@Model.Role" class="form-control" readonly tabindex="-1" />
                            </div>
                            @if (Model.Role == Roles.AirlineExecutive && !string.IsNullOrWhiteSpace(Model.Airline))
                            {
                                <div class="col-md-6">
                                    <label asp-for="Airline" class="form-label"></label>
                                    <input value="@Model.Airline" class="form-control" readonly tabindex="-1" />
                                </div>
                            }
                            @if (Model.Role == Roles.FuelSupplyExecutive && !string.IsNullOrWhiteSpace(Model.FuelCompany))
                            {
                                <div class="col-md-6">
                                    <label asp-for="FuelCompany" class="form-label"></label>
                                    <input value="@Model.FuelCompany" class="form-control" readonly tabindex="-1" />
                                </div>
                            }
                            @if (Model.Role == Roles.FuelCoordinator && !string.IsNullOrWhiteSpace(Model.Airport))
                            {
                                <div class="col-md-6">
                                    <label asp-for="Airport" class="form-label"></label>
                                    <input value="@Model.Airport" class="form-control" readonly tabindex="-1" />
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top">
                    <button type="submit" class="btn btn-primary" id="submitBtn">
                        <i class="fas fa-check me-1" aria-hidden="true"></i>Update profile
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        $('#profileForm').on('submit', function () {
            if (!$(this).valid()) return;
            $('#submitBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i>Updating...');
        });
    </script>
}
