@model AeroFuelHub.Web.ViewModels.Profile.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
    ViewData["Subtitle"] = "Update your account password";
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1" aria-hidden="true"></i>Back to profile
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card card-app">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-key me-2 text-primary" aria-hidden="true"></i>Change password
                </h3>
            </div>
            <form method="post" id="changePasswordForm">
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock" aria-hidden="true"></i></span>
                            <input asp-for="CurrentPassword" type="password" class="form-control password-field" autocomplete="current-password" />
                            <button type="button" class="btn btn-outline-secondary togglePassword" aria-label="Show password">
                                <i class="fas fa-eye" aria-hidden="true"></i>
                            </button>
                        </div>
                        <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock" aria-hidden="true"></i></span>
                            <input asp-for="NewPassword" type="password" class="form-control password-field" autocomplete="new-password" />
                            <button type="button" class="btn btn-outline-secondary togglePassword" aria-label="Show password">
                                <i class="fas fa-eye" aria-hidden="true"></i>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-0">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock" aria-hidden="true"></i></span>
                            <input asp-for="ConfirmPassword" type="password" class="form-control password-field" autocomplete="new-password" />
                            <button type="button" class="btn btn-outline-secondary togglePassword" aria-label="Show password">
                                <i class="fas fa-eye" aria-hidden="true"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top d-flex flex-wrap gap-2 justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary" id="submitBtn">
                        <i class="fas fa-check me-1" aria-hidden="true"></i>Change password
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        $('.togglePassword').on('click', function () {
            const input = $(this).closest('.input-group').find('input');
            const isPassword = input.attr('type') === 'password';
            input.attr('type', isPassword ? 'text' : 'password');
            $(this).find('i').toggleClass('fa-eye fa-eye-slash');
        });

        $('#changePasswordForm').on('submit', function () {
            if (!$(this).valid()) return;
            $('#submitBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i>Updating...');
        });
    </script>
}
