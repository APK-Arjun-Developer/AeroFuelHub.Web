@model AeroFuelHub.Web.ViewModels.MasterData.FuelCompanyFormViewModel

@{
    ViewData["Title"] = "Edit Fuel Company";
    ViewData["Subtitle"] = "Update fuel company details";
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1" aria-hidden="true"></i>Back to fuel companies
    </a>
</div>

<div class="card card-app">
    <div class="card-header">
        <h3 class="card-title mb-0">
            <i class="fas fa-pen me-2 text-primary" aria-hidden="true"></i>Edit fuel company
        </h3>
    </div>

    <form asp-action="Edit" method="post" id="fuelCompanyForm">
        <input type="hidden" asp-for="Id" />
        <div class="card-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="card-footer bg-transparent border-top d-flex flex-wrap gap-2 justify-content-between align-items-center">
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary" id="submitBtn">
                <i class="fas fa-check me-1" aria-hidden="true"></i>Update
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        $('#fuelCompanyForm').on('submit', function () {
            if (!$(this).valid()) return;
            $('#submitBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i>Updating...');
        });
    </script>
}

