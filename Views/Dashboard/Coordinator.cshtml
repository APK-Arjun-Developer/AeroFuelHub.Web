@{
    ViewData["Title"] = "Fuel Coordinator Dashboard";
}

<div class="row">

    <div class="col-md-4">

        <div class="card">

            <div class="card-body text-center">

                <i class="fas fa-plus-circle fa-3x text-primary"></i>

                <h4 class="mt-3">
                    Create Fuel Entry
                </h4>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card">

            <div class="card-body text-center">

                <i class="fas fa-file-invoice fa-3x text-success"></i>

                <h4 class="mt-3">
                    Generate Invoice
                </h4>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card">

            <div class="card-body text-center">

                <i class="fas fa-history fa-3x text-warning"></i>

                <h4 class="mt-3">
                    Transaction History
                </h4>

            </div>

        </div>

    </div>

</div>