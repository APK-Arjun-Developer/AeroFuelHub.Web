@{
    ViewData["Title"] = "Fuel Coordinator Dashboard";
}

<div class="row">

    <div class="col-md-4">

        <a asp-controller="FuelTransaction"
           asp-action="Create"
           class="text-decoration-none">

            <div class="card">

                <div class="card-body text-center">

                    <i class="fas fa-plus-circle fa-3x text-primary"></i>

                    <h4 class="mt-3 text-dark">
                        Create Fuel Entry
                    </h4>

                </div>

            </div>

        </a>

    </div>

    <div class="col-md-4">

        <a asp-controller="FuelTransaction"
           asp-action="Reports"
           class="text-decoration-none">

            <div class="card">

                <div class="card-body text-center">

                    <i class="fas fa-file-invoice fa-3x text-success"></i>

                    <h4 class="mt-3 text-dark">
                        Reports
                    </h4>

                </div>

            </div>

        </a>

    </div>

    <div class="col-md-4">

        <a asp-controller="FuelTransaction"
           asp-action="History"
           class="text-decoration-none">

            <div class="card">

                <div class="card-body text-center">

                    <i class="fas fa-history fa-3x text-warning"></i>

                    <h4 class="mt-3 text-dark">
                        Transaction History
                    </h4>

                </div>

            </div>

        </a>

    </div>

</div>