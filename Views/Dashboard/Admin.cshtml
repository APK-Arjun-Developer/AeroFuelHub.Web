@model AeroFuelHub.Web.ViewModels.Dashboard.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="row">

    <div class="col-lg-3 col-6">

        <div class="small-box bg-info">

            <div class="inner">

                <h3>@Model.TotalTransactions</h3>

                <p>Total Transactions</p>

            </div>

            <div class="icon">

                <i class="fas fa-gas-pump"></i>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-6">

        <div class="small-box bg-success">

            <div class="inner">

                <h3>@Model.TotalRevenue</h3>

                <p>Total Revenue</p>

            </div>

            <div class="icon">

                <i class="fas fa-dollar-sign"></i>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-6">

        <div class="small-box bg-warning">

            <div class="inner">

                <h3>@Model.TotalFuelQuantity</h3>

                <p>Total Fuel Quantity</p>

            </div>

            <div class="icon">

                <i class="fas fa-oil-can"></i>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-6">

        <div class="small-box bg-danger">

            <div class="inner">

                <h3>@Model.TotalAirlines</h3>

                <p>Total Airlines</p>

            </div>

            <div class="icon">

                <i class="fas fa-plane"></i>

            </div>

        </div>

    </div>

</div>

<div class="row">

    <div class="col-md-8">

        <div class="card">

            <div class="card-header">

                <h3 class="card-title">

                    Monthly Transactions

                </h3>

            </div>

            <div class="card-body">

                <canvas id="transactionChart" height="100">
                </canvas>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card">

            <div class="card-header">

                <h3 class="card-title">

                    Recent Transactions

                </h3>

            </div>

            <div class="card-body">

                <ul class="list-group">

                    @foreach (var item in Model.RecentTransactions)
                    {
                        <li class="list-group-item">

                            <strong>
                                @item.TransactionNumber
                            </strong>

                            <br />

                            @item.Airline

                            <br />

                            ₹ @item.TotalAmount

                        </li>
                    }

                </ul>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <script>

        const ctx =
            document.getElementById('transactionChart');

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels:
        @Html.Raw(
            JsonSerializer.Serialize(
                    Model.ChartLabels)),

            datasets: [{
                label: 'Transactions',
                data:
        @Html.Raw(
                        JsonSerializer.Serialize(
                                Model.ChartData))
}]
        }
    });

</script>

}