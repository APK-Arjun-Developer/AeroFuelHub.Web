@model AeroFuelHub.Web.ViewModels.Dashboard.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="row">

    <div class="col-lg-3 col-6">

        <div class="small-box bg-info">

            <div class="inner">

                <h3>@Model.TotalTransactions</h3>

                <p>Total Transactions</p>

            </div>

            <div class="icon">

                <i class="fas fa-gas-pump"></i>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-6">

        <div class="small-box bg-success">

            <div class="inner">

                <h3>₹ @Model.TotalRevenue.ToString("N2")</h3>

                <p>Total Revenue</p>

            </div>

            <div class="icon">

                <i class="fas fa-dollar-sign"></i>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-6">

        <div class="small-box bg-warning">

            <div class="inner">

                <h3>@Model.TotalFuelQuantity</h3>

                <p>Total Fuel Quantity</p>

            </div>

            <div class="icon">

                <i class="fas fa-oil-can"></i>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-6">

        <div class="small-box bg-danger">

            <div class="inner">

                <h3>@Model.TotalAirlines</h3>

                <p>Total Airlines</p>

            </div>

            <div class="icon">

                <i class="fas fa-plane"></i>

            </div>

        </div>

    </div>

</div>

<div class="row">

    <div class="col-md-8">

        <div class="card">

            <div class="card-header">

                <h3 class="card-title">

                    Monthly Transactions

                </h3>

            </div>

            <div class="card-body">

                <canvas id="transactionChart" height="100">
                </canvas>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card">

            <div class="card-header">

                <h3 class="card-title">

                    Recent Transactions

                </h3>

            </div>

            <div class="card-body">

                <ul class="list-group">

                    @foreach (var item in Model.RecentTransactions)
                    {
                        <li class="list-group-item">

                            <strong>
                                @item.TransactionNumber
                            </strong>

                            <br />

                            @item.Airline

                            <br />

                            ₹ @item.TotalAmount.ToString("N2")

                        </li>
                    }

                </ul>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <script>
        function getChartTheme() {
            const isDark = document.getElementById('bodyElement').classList.contains('dark-mode');
            return {
                text: isDark ? '#e9ecef' : '#495057',
                grid: isDark ? '#454d55' : '#dee2e6',
                bar: isDark ? 'rgba(54, 162, 235, 0.85)' : 'rgba(0, 123, 255, 0.75)',
                barBorder: isDark ? 'rgba(54, 162, 235, 1)' : 'rgba(0, 123, 255, 1)'
            };
        }

        function buildChart() {
            const theme = getChartTheme();
            const ctx = document.getElementById('transactionChart');

            return new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(JsonSerializer.Serialize(Model.ChartLabels)),
                    datasets: [{
                        label: 'Transactions',
                        data: @Html.Raw(JsonSerializer.Serialize(Model.ChartData)),
                        backgroundColor: theme.bar,
                        borderColor: theme.barBorder,
                        borderWidth: 1,
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            labels: { color: theme.text }
                        }
                    },
                    scales: {
                        x: {
                            ticks: { color: theme.text },
                            grid: { color: theme.grid }
                        },
                        y: {
                            beginAtZero: true,
                            ticks: {
                                color: theme.text,
                                stepSize: 1
                            },
                            grid: { color: theme.grid }
                        }
                    }
                }
            });
        }

        let transactionChart = buildChart();

        document.getElementById('bodyElement')?.addEventListener('themechange', function () {
            setTimeout(function () {
                transactionChart.destroy();
                transactionChart = buildChart();
            }, 50);
        });
    </script>

}