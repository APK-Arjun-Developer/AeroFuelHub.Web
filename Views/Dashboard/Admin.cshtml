@model AeroFuelHub.Web.ViewModels.Dashboard.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    ViewData["Subtitle"] = "Overview of transactions, revenue, and platform activity";
}

<div class="quick-actions">
    <a asp-controller="FuelTransaction" asp-action="Create" class="btn btn-primary btn-sm">
        <i class="fas fa-plus-circle me-1" aria-hidden="true"></i>New fuel entry
    </a>
    <a asp-controller="FuelTransaction" asp-action="History" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-gas-pump me-1" aria-hidden="true"></i>All transactions
    </a>
    <a asp-controller="FuelTransaction" asp-action="Reports" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-chart-bar me-1" aria-hidden="true"></i>Reports
    </a>
    <a asp-controller="User" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-users me-1" aria-hidden="true"></i>Manage users
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-4 col-md-6">
        <div class="stat-card stat-card--primary">
            <div class="stat-card__icon"><i class="fas fa-gas-pump" aria-hidden="true"></i></div>
            <div>
                <span class="stat-card__value">@Model.TotalTransactions.ToString("N0")</span>
                <span class="stat-card__label">Total transactions</span>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6">
        <div class="stat-card stat-card--success">
            <div class="stat-card__icon"><i class="fas fa-indian-rupee-sign" aria-hidden="true"></i></div>
            <div>
                <span class="stat-card__value">₹@Model.TotalRevenue.ToString("N0")</span>
                <span class="stat-card__label">Total revenue</span>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6">
        <div class="stat-card stat-card--warning">
            <div class="stat-card__icon"><i class="fas fa-oil-can" aria-hidden="true"></i></div>
            <div>
                <span class="stat-card__value">@Model.TotalFuelQuantity.ToString("N0")</span>
                <span class="stat-card__label">Total fuel quantity (L)</span>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6">
        <div class="stat-card stat-card--info">
            <div class="stat-card__icon"><i class="fas fa-plane" aria-hidden="true"></i></div>
            <div>
                <span class="stat-card__value">@Model.TotalAirlines</span>
                <span class="stat-card__label">Airlines</span>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6">
        <div class="stat-card stat-card--danger">
            <div class="stat-card__icon"><i class="fas fa-building" aria-hidden="true"></i></div>
            <div>
                <span class="stat-card__value">@Model.TotalFuelCompanies</span>
                <span class="stat-card__label">Fuel companies</span>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6">
        <div class="stat-card stat-card--purple">
            <div class="stat-card__icon"><i class="fas fa-location-dot" aria-hidden="true"></i></div>
            <div>
                <span class="stat-card__value">@Model.TotalAirports</span>
                <span class="stat-card__label">Airports</span>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card card-app">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title">Monthly transactions</h3>
                <span class="badge text-bg-light text-secondary fw-normal">Last 12 months</span>
            </div>
            <div class="card-body">
                <canvas id="transactionChart" height="120"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card card-app h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title">Recent transactions</h3>
                <a asp-controller="FuelTransaction" asp-action="History" class="small text-decoration-none">View all</a>
            </div>
            <div class="card-body pt-0">
                @if (Model.RecentTransactions.Count == 0)
                {
                    <div class="recent-txn-empty">
                        <i class="fas fa-inbox fa-2x mb-2 d-block opacity-50" aria-hidden="true"></i>
                        No transactions yet
                    </div>
                }
                else
                {
                    <ul class="recent-txn-list">
                        @foreach (var item in Model.RecentTransactions)
                        {
                            <li>
                                <a asp-controller="FuelTransaction" asp-action="Details" asp-route-id="@item.Id"
                                    class="recent-txn-item">
                                    <div class="recent-txn-item__top">
                                        <span class="recent-txn-item__id">@item.TransactionNumber</span>
                                        <span class="recent-txn-item__amount">₹@item.TotalAmount.ToString("N2")</span>
                                    </div>
                                    <div class="recent-txn-item__meta">
                                        @item.Airline · @item.TransactionDate.ToString("dd MMM yyyy")
                                    </div>
                                </a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function getChartTheme() {
            const isDark = document.getElementById('bodyElement').classList.contains('dark-mode');
            return {
                text: isDark ? '#e9ecef' : '#64748b',
                grid: isDark ? '#454d55' : '#e2e8f0',
                bar: isDark ? 'rgba(14, 165, 233, 0.85)' : 'rgba(11, 61, 110, 0.75)',
                barBorder: isDark ? 'rgba(14, 165, 233, 1)' : 'rgba(11, 61, 110, 1)'
            };
        }

        function buildChart() {
            const theme = getChartTheme();
            const ctx = document.getElementById('transactionChart');

            return new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(JsonSerializer.Serialize(Model.ChartLabels)),
                    datasets: [{
                        label: 'Transactions',
                        data: @Html.Raw(JsonSerializer.Serialize(Model.ChartData)),
                        backgroundColor: theme.bar,
                        borderColor: theme.barBorder,
                        borderWidth: 1,
                        borderRadius: 6,
                        borderSkipped: false
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        x: {
                            ticks: { color: theme.text },
                            grid: { display: false }
                        },
                        y: {
                            beginAtZero: true,
                            ticks: {
                                color: theme.text,
                                stepSize: 1,
                                precision: 0
                            },
                            grid: { color: theme.grid }
                        }
                    }
                }
            });
        }

        let transactionChart = buildChart();

        document.getElementById('bodyElement')?.addEventListener('themechange', function () {
            setTimeout(function () {
                transactionChart.destroy();
                transactionChart = buildChart();
            }, 50);
        });
    </script>
}
