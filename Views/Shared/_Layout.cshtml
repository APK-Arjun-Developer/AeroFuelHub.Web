@{
    var currentController =
    ViewContext.RouteData.Values["controller"]?.ToString();

    var currentAction =
    ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - AeroFuel Hub</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- AdminLTE -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" />

    <style>
        .dark-mode {
            background-color: #343a40 !important;
            color: #fff !important;
        }

        .dark-mode .main-header {
            background-color: #343a40 !important;
            border-bottom: 1px solid #454d55;
        }

        .dark-mode .main-header .nav-link {
            color: #fff !important;
        }

        .dark-mode .navbar-nav .nav-link i {
            color: #fff !important;
        }

        .dark-mode .main-sidebar {
            background-color: #2b2f33 !important;
        }

        .dark-mode .nav-sidebar .nav-link {
            color: #c2c7d0 !important;
        }

        .dark-mode .nav-sidebar .nav-link.active {
            background-color: #007bff !important;
            color: #fff !important;
        }

        .dark-mode .nav-sidebar .nav-icon {
            color: #c2c7d0 !important;
        }

        .dark-mode .brand-link {
            background-color: #2b2f33 !important;
            color: #fff !important;
        }

        .dark-mode .card {
            background-color: #343a40 !important;
            color: #fff !important;
            border: 1px solid #454d55;
        }

        .dark-mode .card-header {
            background-color: #3f474e !important;
            border-bottom: 1px solid #454d55;
        }

        .dark-mode .table {
            --bs-table-bg: #343a40;
            --bs-table-color: #fff;
            --bs-table-striped-bg: #3b434a;
            --bs-table-active-bg: #454d55;
            --bs-table-hover-bg: #454d55;
            --bs-table-border-color: #4b545c;
            background-color: #343a40 !important;
            color: #fff !important;
        }

        .dark-mode .table> :not(caption)>*>* {
            background-color: #343a40 !important;
            color: #fff !important;
            box-shadow: none !important;
        }

        .dark-mode .table thead th {
            background-color: #3f474e !important;
            color: #fff !important;
        }

        .dark-mode .table tbody tr:hover>* {
            background-color: #454d55 !important;
            color: #fff !important;
        }

        .dark-mode .table-bordered td,
        .dark-mode .table-bordered th {
            border-color: #4b545c !important;
        }

        .dark-mode .dataTables_wrapper {
            color: #fff !important;
        }

        .dark-mode .dataTables_wrapper .dataTables_length,
        .dark-mode .dataTables_wrapper .dataTables_filter,
        .dark-mode .dataTables_wrapper .dataTables_info,
        .dark-mode .dataTables_wrapper .dataTables_paginate {
            color: #fff !important;
        }

        .dark-mode .dataTables_wrapper input,
        .dark-mode .dataTables_wrapper select {
            background-color: #454d55 !important;
            color: #fff !important;
            border: 1px solid #6c757d !important;
        }

        .dark-mode .page-link {
            background-color: #343a40 !important;
            color: #fff !important;
            border-color: #454d55 !important;
        }

        .dark-mode .page-item.active .page-link {
            background-color: #007bff !important;
            border-color: #007bff !important;
        }

        .dark-mode .form-control,
        .dark-mode .form-select {
            background-color: #454d55 !important;
            color: #fff !important;
            border-color: #6c757d !important;
        }

        .dark-mode .form-control:focus,
        .dark-mode .form-select:focus {
            background-color: #454d55 !important;
            color: #fff !important;
        }

        .dark-mode .dropdown-menu {
            background-color: #343a40 !important;
            border: 1px solid #454d55;
        }

        .dark-mode .dropdown-item {
            color: #fff !important;
        }

        .dark-mode .dropdown-item:hover {
            background-color: #495057 !important;
        }

        .dark-mode table.dataTable tbody tr,
        .dark-mode table.dataTable tbody td,
        .dark-mode table.dataTable thead th {
            background-color: #343a40 !important;
            color: #fff !important;
        }

        .dark-mode table.dataTable.stripe tbody tr.odd,
        .dark-mode table.dataTable.display tbody tr.odd {
            background-color: #3b434a !important;
        }

        .dark-mode table.dataTable.hover tbody tr:hover,
        .dark-mode table.dataTable.display tbody tr:hover {
            background-color: #495057 !important;
        }

        .dark-mode table.dataTable thead th {
            border-bottom: 1px solid #4b545c !important;
        }

        .dark-mode table.dataTable tbody td {
            border-color: #4b545c !important;
        }

        body.layout-fixed .main-header {
            position: fixed !important;
            top: 0;
            right: 0;
            left: 0;
            z-index: 1030;
        }

        body.layout-fixed .content-wrapper {
            margin-top: calc(3.5rem + 1px);
        }

        @@media (min-width: 768px) {
            body.layout-fixed:not(.sidebar-collapse) .main-header {
                margin-left: 250px;
            }

            body.layout-fixed.sidebar-collapse .main-header {
                margin-left: 4.6rem;
            }
        }
    </style>
</head>

<body id="bodyElement" class="hold-transition sidebar-mini layout-fixed layout-navbar-fixed">

    <div class="wrapper">

        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light">

            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#">
                        <i class="fas fa-bars"></i>
                    </a>
                </li>
            </ul>

            <ul class="navbar-nav ms-auto">

                @if (User.Identity!.IsAuthenticated)
                {
                    <li class="nav-item">
                        <div class="dropdown">

                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">

                                @User.Identity!.Name

                            </a>

                            <div class="dropdown-menu dropdown-menu-end">

                                <a class="dropdown-item" asp-controller="Profile" asp-action="Index">

                                    My Profile

                                </a>

                                <a class="dropdown-item" asp-controller="Profile" asp-action="ChangePassword">

                                    Change Password

                                </a>

                                <div class="dropdown-divider"></div>

                                <a class="dropdown-item" asp-controller="Account" asp-action="Logout">

                                    Logout

                                </a>

                            </div>

                        </div>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#" id="darkModeToggle">
                            <i class="fas fa-moon"></i>
                        </a>
                    </li>
                }

            </ul>

        </nav>

        <!-- Sidebar -->
        <aside class="main-sidebar sidebar-light-primary elevation-4">

            <a asp-controller="Dashboard" asp-action="Index" class="brand-link d-flex align-items-center">

                <img src="~/images/logo.png" alt="AeroFuel Hub Logo" class="brand-image img-circle elevation-2" style="opacity: .9;
                width: 34px;
                height: 34px;
                object-fit: contain;
                background: transparent;" />

                <span class="brand-text fw-light ms-2">
                    AeroFuel Hub
                </span>

            </a>

            <div class="sidebar">

                <nav class="mt-2">

                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu">

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a asp-controller="Dashboard" asp-action="Admin"
                                    class="nav-link @(currentController == "Dashboard"
                                                                                                                                                                                                                                                                                                         && currentAction == "Admin" ? "active" : "")">

                                <i class="nav-icon fas fa-chart-line"></i>

                                    <p>Dashboard</p>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a asp-controller="FuelTransaction" asp-action="Create"
                                    class="nav-link @(
                                                                                                                                                                                                                                                                                                                                                                            currentController == "FuelTransaction"
                                                                                                                                                                                                                                                                                                                                                                            && currentAction == "Create"
                                                                                                                                                                                                                                                                                                                                                                                ? "active"
                                                                                                                                                                                                                                                                                                                                                                                : "")">

                                <i class="nav-icon fas fa-plus-circle"></i>

                                    <p>Create Fuel Entry</p>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a asp-controller="User" asp-action="Index"
                                    class="nav-link @(currentController == "User"
                                                                                                                                                                                                                && (
                                                                                                                                                                                                                    currentAction == "Index"
                                                                                                                                                                                                                    || currentAction == "Create"
                                                                                                                                                                                                                    || currentAction == "Edit"
                                                                                                                                                                                                                ) ? "active" : "")">

                                <i class="nav-icon fas fa-users"></i>

                                    <p>Users</p>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a asp-controller="FuelTransaction" asp-action="History"
                                    class="nav-link @(currentController == "FuelTransaction"
                                                                                                                                                                                                                                                                                                          && currentAction == "History"
                                                                                                                                                                                                                                                                                                          ? "active"
                                                                                                                                                                                                                                                                                                          : "")">

                                <i class="nav-icon fas fa-gas-pump"></i>

                                    <p>Fuel Transactions</p>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a asp-controller="FuelTransaction" asp-action="Reports"
                                    class="nav-link @(currentController == "FuelTransaction"
                                                                                                                                                                                                                                                                                     && currentAction == "Reports" ? "active" : "")">

                                <i class="nav-icon fas fa-chart-bar"></i>

                                    <p>Reports</p>
                                </a>
                            </li>
                                                }

                        @if (User.IsInRole("FuelCoordinator"))
                        {
                            <li class="nav-item">
                                <a asp-controller="Dashboard" asp-action="Coordinator"
                                    class="nav-link @(currentController == "Dashboard"
                                                                                                                                                                                                                                                                           && currentAction == "Coordinator" ? "active" : "")">

                                <i class="nav-icon fas fa-chart-pie"></i>

                                    <p>Dashboard</p>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a asp-controller="FuelTransaction" asp-action="Create"
                                    class="nav-link @(
                                                                                                                                                                                                                                                                                                                                            currentController == "FuelTransaction"
                                                                                                                                                                                                                                                                                                                                            && currentAction == "Create"
                                                                                                                                                                                                                                                                                                                                                ? "active"
                                                                                                                                                                                                                                                                                                                                                : "")">

                                <i class="nav-icon fas fa-plus-circle"></i>

                                    <p>Create Fuel Entry</p>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a asp-controller="FuelTransaction" asp-action="History"
                                    class="nav-link @(currentController == "FuelTransaction"
                                                                                                                                                                                                                                                                                                                     && currentAction == "History" ? "active" : "")">

                                <i class="nav-icon fas fa-history"></i>

                                    <p>Transaction History</p>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a asp-controller="FuelTransaction" asp-action="Reports"
                                    class="nav-link @(currentController == "FuelTransaction"
                                                                                                                                                                                                                                                                                     && currentAction == "Reports" ? "active" : "")">

                                <i class="nav-icon fas fa-chart-bar"></i>

                                    <p>Reports</p>
                                </a>
                            </li>
                                                }

                        @if (User.IsInRole("AirlineExecutive"))
                        {
                            <li class="nav-item">
                                <a asp-controller="Dashboard" asp-action="Airline"
                                    class="nav-link @(currentController == "Dashboard"
                                                                                                                                                                                                                                                                       && currentAction == "Airline" ? "active" : "")">

                                <i class="nav-icon fas fa-chart-line"></i>

                                    <p>Dashboard</p>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a asp-controller="FuelTransaction" asp-action="History"
                                    class="nav-link @(currentController == "FuelTransaction"
                                                                                                                                                                                                                                                     && currentAction == "History" ? "active" : "")">

                                <i class="nav-icon fas fa-gas-pump"></i>

                                    <p>Fuel Transactions</p>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a asp-controller="FuelTransaction" asp-action="Reports"
                                    class="nav-link @(currentController == "FuelTransaction"
                                                                                                                                                                                                                                                                                         && currentAction == "Reports" ? "active" : "")">

                                <i class="nav-icon fas fa-chart-bar"></i>

                                    <p>Reports</p>
                                </a>
                            </li>
                                                }

                        @if (User.IsInRole("FuelSupplyExecutive"))
                        {
                            <li class="nav-item">
                                <a asp-controller="Dashboard" asp-action="FuelSupply"
                                    class="nav-link @(currentController == "Dashboard"
                                                                                                                                                                                                                                      && currentAction == "FuelSupply" ? "active" : "")">

                                <i class="nav-icon fas fa-chart-pie"></i>

                                    <p>Dashboard</p>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a asp-controller="FuelTransaction" asp-action="History"
                                    class="nav-link @(currentController == "FuelTransaction"
                                                                                                                                                                                                                     && currentAction == "History" ? "active" : "")">

                                <i class="nav-icon fas fa-gas-pump"></i>

                                    <p>Fuel Transactions</p>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a asp-controller="FuelTransaction" asp-action="Reports"
                                    class="nav-link @(currentController == "FuelTransaction"
                                                                                                                                                                                                                                                                                             && currentAction == "Reports" ? "active" : "")">

                                <i class="nav-icon fas fa-chart-bar"></i>

                                    <p>Reports</p>
                                </a>
                            </li>
                                                }

                    </ul>

                </nav>

            </div>

        </aside>

        <!-- Content Wrapper -->
        <div class="content-wrapper">

            <section class="content-header">

                <div class="container-fluid">

                    <div class="row mb-2">

                        <div class="col-sm-6">
                            <h1>@ViewData["Title"]</h1>
                        </div>

                    </div>

                </div>

            </section>

            <section class="content">

                <div class="container-fluid">

                    @RenderBody()

                </div>

            </section>

        </div>

        <!-- Footer -->
        <footer class="main-footer">

            <strong>
                AeroFuel Hub
            </strong>

        </footer>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>

        const body =
            document.getElementById('bodyElement');

        const darkModeToggle =
            document.getElementById('darkModeToggle');

        if (localStorage.getItem('dark-mode') === 'enabled') {

            body.classList.add('dark-mode');
        }

        darkModeToggle.addEventListener('click', function () {

            body.classList.toggle('dark-mode');

            if (body.classList.contains('dark-mode')) {

                localStorage.setItem(
                    'dark-mode',
                    'enabled');
            }
            else {

                localStorage.setItem(
                    'dark-mode',
                    'disabled');
            }
        });

    </script>

    @await Component.InvokeAsync("Notyf")

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
