@using AeroFuelHub.Web.Constants
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    bool IsActive(string controller, params string[] actions) =>
    currentController == controller && actions.Contains(currentAction);

    var isAdministrationOpen = currentController is "User" or "Airlines" or "Aircrafts" or "FuelCompanies" or "Airports";
}

<aside class="main-sidebar sidebar-light-primary elevation-4">

    <a asp-controller="Home" asp-action="Index" class="brand-link d-flex align-items-center">

        <img src="~/images/logo.png" alt="AeroFuel Hub Logo" class="brand-image brand-logo img-circle elevation-2" />

        <span class="brand-text fw-semibold ms-2">AeroFuel Hub</span>

    </a>

    <div class="sidebar">

        <nav class="mt-2">

            <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu">

                @if (User.IsInRole(Roles.Admin))
                {
                    <li class="nav-item">
                        <a asp-controller="Dashboard" asp-action="Admin"
                            class="nav-link @(IsActive("Dashboard", "Admin") ? "active" : "")">
                            <i class="nav-icon fas fa-chart-line"></i>
                            <p>Dashboard</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="FuelTransaction" asp-action="Create"
                            class="nav-link @(IsActive("FuelTransaction", "Create") ? "active" : "")">
                            <i class="nav-icon fas fa-plus-circle"></i>
                            <p>Create Fuel Entry</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="FuelTransaction" asp-action="History"
                            class="nav-link @(IsActive("FuelTransaction", "History", "Details") ? "active" : "")">
                            <i class="nav-icon fas fa-gas-pump"></i>
                            <p>Fuel Transactions</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="FuelTransaction" asp-action="Reports"
                            class="nav-link @(IsActive("FuelTransaction", "Reports") ? "active" : "")">
                            <i class="nav-icon fas fa-chart-bar"></i>
                            <p>Reports</p>
                        </a>
                    </li>

                    <li class="nav-item @(isAdministrationOpen ? "menu-open" : "")">
                        <a href="#" class="nav-link @(isAdministrationOpen ? "active" : "")">
                            <i class="nav-icon fas fa-user-shield"></i>
                            <p>
                                Administration
                                <i class="right fas fa-angle-left"></i>
                            </p>
                        </a>
                        <ul class="nav nav-treeview">
                            <li class="nav-item">
                                <a asp-controller="User" asp-action="Index"
                                   class="nav-link @(IsActive("User", "Index", "Create", "Edit") ? "active" : "")">
                                    <p>Users</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="Airlines" asp-action="Index"
                                   class="nav-link @(IsActive("Airlines", "Index", "Create", "Edit") ? "active" : "")">
                                    <p>Airlines</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="Aircrafts" asp-action="Index"
                                   class="nav-link @(IsActive("Aircrafts", "Index", "Create", "Edit") ? "active" : "")">
                                    <p>Aircraft</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="FuelCompanies" asp-action="Index"
                                   class="nav-link @(IsActive("FuelCompanies", "Index", "Create", "Edit") ? "active" : "")">
                                    <p>Fuel Companies</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="Airports" asp-action="Index"
                                   class="nav-link @(IsActive("Airports", "Index", "Create", "Edit") ? "active" : "")">
                                    <p>Airports</p>
                                </a>
                            </li>
                        </ul>
                    </li>
                }

                @if (User.IsInRole(Roles.FuelCoordinator))
                {
                    <li class="nav-item">
                        <a asp-controller="Dashboard" asp-action="Coordinator"
                            class="nav-link @(IsActive("Dashboard", "Coordinator") ? "active" : "")">
                            <i class="nav-icon fas fa-chart-pie"></i>
                            <p>Dashboard</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="FuelTransaction" asp-action="Create"
                            class="nav-link @(IsActive("FuelTransaction", "Create") ? "active" : "")">
                            <i class="nav-icon fas fa-plus-circle"></i>
                            <p>Create Fuel Entry</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="FuelTransaction" asp-action="History"
                            class="nav-link @(IsActive("FuelTransaction", "History", "Details") ? "active" : "")">
                            <i class="nav-icon fas fa-history"></i>
                            <p>Transaction History</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="FuelTransaction" asp-action="Reports"
                            class="nav-link @(IsActive("FuelTransaction", "Reports") ? "active" : "")">
                            <i class="nav-icon fas fa-chart-bar"></i>
                            <p>Reports</p>
                        </a>
                    </li>
                }

                @if (User.IsInRole(Roles.AirlineExecutive))
                {
                    <li class="nav-item">
                        <a asp-controller="Dashboard" asp-action="Airline"
                            class="nav-link @(IsActive("Dashboard", "Airline") ? "active" : "")">
                            <i class="nav-icon fas fa-chart-line"></i>
                            <p>Dashboard</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="FuelTransaction" asp-action="History"
                            class="nav-link @(IsActive("FuelTransaction", "History", "Details") ? "active" : "")">
                            <i class="nav-icon fas fa-gas-pump"></i>
                            <p>Fuel Transactions</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="FuelTransaction" asp-action="Reports"
                            class="nav-link @(IsActive("FuelTransaction", "Reports") ? "active" : "")">
                            <i class="nav-icon fas fa-chart-bar"></i>
                            <p>Reports</p>
                        </a>
                    </li>
                }

                @if (User.IsInRole(Roles.FuelSupplyExecutive))
                {
                    <li class="nav-item">
                        <a asp-controller="Dashboard" asp-action="FuelSupply"
                            class="nav-link @(IsActive("Dashboard", "FuelSupply") ? "active" : "")">
                            <i class="nav-icon fas fa-chart-pie"></i>
                            <p>Dashboard</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="FuelTransaction" asp-action="History"
                            class="nav-link @(IsActive("FuelTransaction", "History", "Details") ? "active" : "")">
                            <i class="nav-icon fas fa-gas-pump"></i>
                            <p>Fuel Transactions</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="FuelTransaction" asp-action="Reports"
                            class="nav-link @(IsActive("FuelTransaction", "Reports") ? "active" : "")">
                            <i class="nav-icon fas fa-chart-bar"></i>
                            <p>Reports</p>
                        </a>
                    </li>
                }

            </ul>

        </nav>

    </div>

</aside>
