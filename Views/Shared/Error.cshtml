@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
    ViewData["Subtitle"] = "An error occurred while processing your request";
    var isDevelopment = Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="status-page">
    <div class="status-card" style="max-width: 560px;">
        <div class="status-icon status-icon--danger" aria-hidden="true">
            <i class="fas fa-circle-exclamation"></i>
        </div>
        <h2>An error occurred</h2>
        <p>We couldn't process your request. Please try again or contact support if this continues.</p>

        @if (Model.ShowRequestId)
        {
            <p class="small text-muted mb-3">
                <strong>Request ID:</strong>
                <code class="user-select-all">@Model.RequestId</code>
            </p>
        }

        <div class="status-actions">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="fas fa-home me-2" aria-hidden="true"></i>Go to home
            </a>
            <button type="button" class="btn btn-outline-secondary" onclick="history.back()">
                <i class="fas fa-arrow-left me-2" aria-hidden="true"></i>Go back
            </button>
        </div>

        @if (isDevelopment)
        {
            <div class="alert alert-warning text-start mt-4 mb-0 small" role="alert">
                <strong>Development mode</strong> — enable detailed exception pages locally by running with
                <code>ASPNETCORE_ENVIRONMENT=Development</code>. Do not enable this in production.
            </div>
        }
    </div>
</div>
