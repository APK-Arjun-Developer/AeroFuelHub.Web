@model AeroFuelHub.Web.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign in - AeroFuel Hub</title>

    <link rel="icon" type="image/png" href="~/images/logo.png" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/logo.png" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>

<body>

    <div class="auth-page">

        <aside class="auth-brand" aria-hidden="false">
            <div class="auth-brand-content">
                <img src="~/images/logo.png" alt="" class="auth-brand-logo" />
                <h1>AeroFuel Hub</h1>
                <p>Manage aviation fuel transactions, reporting, and coordination in one secure platform.</p>
                <ul class="auth-features">
                    <li>
                        <i class="fas fa-gas-pump" aria-hidden="true"></i>
                        <span>Track fuel entries and transaction history across airlines and suppliers</span>
                    </li>
                    <li>
                        <i class="fas fa-chart-line" aria-hidden="true"></i>
                        <span>Role-based dashboards and reports for executives and coordinators</span>
                    </li>
                    <li>
                        <i class="fas fa-shield-halved" aria-hidden="true"></i>
                        <span>Secure access with role-based permissions for your organization</span>
                    </li>
                </ul>
            </div>
        </aside>

        <main class="auth-panel">
            <div class="auth-card">
                <header class="auth-card-header">
                    <img src="~/images/logo.png" alt="AeroFuel Hub" class="auth-mobile-logo" />
                    <h2>Welcome back</h2>
                    <p>Sign in to your account to continue</p>
                </header>

                <form asp-action="Login" method="post" class="auth-form">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-envelope" aria-hidden="true"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="you@company.com" autocomplete="username" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock" aria-hidden="true"></i></span>
                            <input asp-for="Password" type="password" class="form-control password-field" placeholder="Enter your password" autocomplete="current-password" />
                            <button type="button" class="btn btn-outline-secondary togglePassword" aria-label="Show password">
                                <i class="fas fa-eye" aria-hidden="true"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-right-to-bracket me-2" aria-hidden="true"></i>Sign in
                    </button>
                </form>

                <p class="auth-footer-note">&copy; @DateTime.UtcNow.Year AeroFuel Hub</p>
            </div>
        </main>

    </div>

    <partial name="_ValidationScriptsPartial" />

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script>
        $('.togglePassword').on('click', function () {
            const input = $(this).closest('.input-group').find('input');
            const isPassword = input.attr('type') === 'password';
            input.attr('type', isPassword ? 'text' : 'password');
            $(this).find('i').toggleClass('fa-eye fa-eye-slash');
            $(this).attr('aria-label', isPassword ? 'Hide password' : 'Show password');
        });
    </script>

</body>

</html>
