@model AeroFuelHub.Web.ViewModels.FuelTransaction.FuelTransactionHistoryViewModel

@{
    ViewData["Title"] = "Transaction History";
}

<div class="card">

    <div class="card-header">

        <form method="get">

            <input type="hidden" name="page" value="1" />

            <div class="row">

                <div class="col-md-4">
                    <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search transaction..." />
                </div>

                <div class="col-md-2">
                    <button class="btn btn-primary">Search</button>
                </div>

            </div>

        </form>

    </div>

    <div class="card-body">

        <div class="table-responsive">

            <table class="table table-bordered table-striped">

                <thead>
                    <tr>
                        <th>Transaction No</th>
                        <th>Airline</th>
                        <th>Aircraft</th>
                        <th>Airport</th>
                        <th>Fuel Company</th>
                        <th>Flight No</th>
                        <th>Total</th>
                        <th>Date</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.TransactionNumber</td>
                            <td>@item.AirlineName</td>
                            <td>@item.AircraftModel</td>
                            <td>@item.AirportName</td>
                            <td>@item.FuelCompanyName</td>
                            <td>@item.FlightNumber</td>
                            <td>₹ @item.TotalAmount.ToString("N2")</td>
                            <td>@item.TransactionDate.ToString("dd MMM yyyy")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>
                                <form asp-action="Delete" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button class="btn btn-danger btn-sm" onclick="return confirm('Delete transaction?')">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="History" asp-route-search="@Model.Search" asp-route-page="@(Model.Page - 1)">Previous</a>
                    </li>
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="History" asp-route-search="@Model.Search" asp-route-page="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="History" asp-route-search="@Model.Search" asp-route-page="@(Model.Page + 1)">Next</a>
                    </li>
                </ul>
            </nav>
            <p class="text-muted text-center mt-2 mb-0">
                Showing @Model.Items.Count of @Model.TotalCount transactions
            </p>
        }

    </div>

</div>
