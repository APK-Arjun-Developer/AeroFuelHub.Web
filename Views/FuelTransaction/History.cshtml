@using AeroFuelHub.Web.Constants
@model AeroFuelHub.Web.ViewModels.FuelTransaction.FuelTransactionHistoryViewModel

@{
    ViewData["Title"] = "Fuel Transactions";
    ViewData["Subtitle"] = "Search and manage fuel transaction records";
}

<div class="card card-app">
    <div class="card-header">
        <form method="get" class="search-toolbar">
            <input type="hidden" name="page" value="1" />
            <div class="input-group search-toolbar__input">
                <span class="input-group-text"><i class="fas fa-search" aria-hidden="true"></i></span>
                <input type="text" name="search" value="@Model.Search" class="form-control"
                       placeholder="Search by transaction no., airline, flight..." />
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-search me-1" aria-hidden="true"></i>Search
            </button>
            @if (!string.IsNullOrWhiteSpace(Model.Search))
            {
                <a asp-action="History" class="btn btn-outline-secondary">Clear</a>
            }
            @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.FuelCoordinator))
            {
                <a asp-action="Create" class="btn btn-outline-primary ms-md-auto">
                    <i class="fas fa-plus-circle me-1" aria-hidden="true"></i>New entry
                </a>
            }
        </form>
    </div>

    <div class="card-body p-0">
        @if (!Model.Items.Any())
        {
            <div class="recent-txn-empty">
                <i class="fas fa-inbox fa-2x mb-2 d-block opacity-50" aria-hidden="true"></i>
                @if (string.IsNullOrWhiteSpace(Model.Search))
                {
                    <span>No transactions found</span>
                }
                else
                {
                    <span>No transactions match your search</span>
                }
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-app table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Transaction</th>
                            <th>Airline</th>
                            <th>Aircraft</th>
                            <th>Airport</th>
                            <th>Fuel company</th>
                            <th>Flight</th>
                            <th class="text-end">Total</th>
                            <th>Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="fw-semibold text-decoration-none">
                                        @item.TransactionNumber
                                    </a>
                                </td>
                                <td>@item.AirlineName</td>
                                <td>@item.AircraftModel</td>
                                <td>@item.AirportName</td>
                                <td>@item.FuelCompanyName</td>
                                <td>@item.FlightNumber</td>
                                <td class="text-end fw-semibold text-primary">₹@item.TotalAmount.ToString("N2")</td>
                                <td class="text-muted">@item.TransactionDate.ToString("dd MMM yyyy")</td>
                                <td class="text-end text-nowrap">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="View details">
                                        <i class="fas fa-eye" aria-hidden="true"></i>
                                    </a>
                                    <form asp-action="Delete" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete transaction"
                                                onclick="return confirm('Delete this transaction?');">
                                            <i class="fas fa-trash" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    @if (Model.TotalCount > 0)
    {
        <div class="card-footer bg-transparent border-top">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                <p class="text-muted small mb-0">
                    Showing page @Model.Page of @Model.TotalPages
                    (@Model.TotalCount transaction@(Model.TotalCount == 1 ? "" : "s") total)
                </p>
                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Transaction pagination">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="History" asp-route-search="@Model.Search" asp-route-page="@(Model.Page - 1)">Previous</a>
                            </li>
                            @for (var i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.Page ? "active" : "")">
                                    <a class="page-link" asp-action="History" asp-route-search="@Model.Search" asp-route-page="@i">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="History" asp-route-search="@Model.Search" asp-route-page="@(Model.Page + 1)">Next</a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    }
</div>
